{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RuneContext Capability Descriptor",
  "description": "Canonical machine-readable RuneContext metadata descriptor.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "binary",
    "release",
    "compatibility",
    "distribution_layouts",
    "project_profiles",
    "capabilities",
    "features",
    "assurance",
    "canonicalization",
    "resolution"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 2
    },
    "binary": {
      "type": "string",
      "const": "runectx"
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package_name", "version", "tag"],
      "properties": {
        "package_name": {
          "type": "string",
          "const": "runecontext"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
        },
        "tag": {
          "type": "string",
          "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_project_version", "directly_supported_project_versions", "upgradeable_from_project_versions", "explicit_upgrade_edges"],
      "properties": {
        "default_project_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
        },
        "directly_supported_project_versions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
          },
          "uniqueItems": true
        },
        "upgradeable_from_project_versions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
          },
          "uniqueItems": true
        },
        "explicit_upgrade_edges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to"],
            "properties": {
              "from": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
              },
              "to": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
              }
            }
          }
        }
      }
    },
    "distribution_layouts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["profile", "schema_path", "adapters_path"],
        "properties": {
          "profile": {
            "type": "string",
            "enum": ["repo_bundle", "installed_share_layout"]
          },
          "schema_path": {
            "type": "string"
          },
          "adapters_path": {
            "type": "string"
          }
        }
      },
      "minItems": 2,
      "allOf": [
        {
          "contains": {
            "type": "object",
            "required": ["profile"],
            "properties": {
              "profile": {"const": "repo_bundle"}
            }
          }
        },
        {
          "contains": {
            "type": "object",
            "required": ["profile"],
            "properties": {
              "profile": {"const": "installed_share_layout"}
            }
          }
        }
      ]
    },
    "project_profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "profile",
          "root_config",
          "content_root",
          "assurance_path",
          "manifest_path",
          "indexes_root"
        ],
        "properties": {
          "profile": {
            "type": "string",
            "enum": ["portable_project_root"]
          },
          "root_config": {
            "type": "string",
            "const": "runecontext.yaml"
          },
          "content_root": {
            "type": "string",
            "const": "runecontext"
          },
          "assurance_path": {
            "type": "string",
            "const": "runecontext/assurance"
          },
          "manifest_path": {
            "type": "string",
            "const": "runecontext/manifest.yaml"
          },
          "indexes_root": {
            "type": "string",
            "const": "runecontext/indexes"
          }
        }
      },
      "minItems": 1,
      "allOf": [
        {
          "contains": {
            "type": "object",
            "required": ["profile"],
            "properties": {
              "profile": {"const": "portable_project_root"}
            }
          }
        }
      ]
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands", "machine_flags", "value_kinds"],
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "token"],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "token": {
                "type": "string",
                "pattern": "^[a-z0-9_]+$"
              },
              "aliases": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^(--?[a-z][a-z0-9-]*)$"
                },
                "uniqueItems": true
              }
            }
          }
        },
        "machine_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["--dry-run", "--explain", "--json", "--non-interactive"]
          },
          "uniqueItems": true
        },
        "value_kinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["none", "text", "enum"]
          },
          "uniqueItems": true
        }
      }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "signed_tag_verification",
          "mutable_ref_opt_in",
          "monorepo_nearest_root_discovery",
          "context_pack_capture",
          "verified_assurance",
          "completion_registry",
          "completion_dynamic_suggestions",
          "generated_indexes",
          "promotion_workflow",
          "upgrade_planning",
          "staged_upgrade_execution",
          "mixed_or_stale_tree_detection"
        ]
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "assurance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tiers", "baseline_supported", "receipt_families"],
      "properties": {
        "tiers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["plain", "verified"]
          },
          "uniqueItems": true,
          "minItems": 2
        },
        "baseline_supported": {
          "type": "boolean"
        },
        "receipt_families": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["context-packs", "changes", "promotions", "verifications"]
          },
          "uniqueItems": true,
          "minItems": 4
        }
      }
    },
    "canonicalization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["context_pack", "assurance_artifacts"],
      "properties": {
        "context_pack": {
          "$ref": "#/$defs/canonicalizationProfile"
        },
        "assurance_artifacts": {
          "$ref": "#/$defs/canonicalizationProfile"
        }
      }
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_modes", "verification_postures"],
      "properties": {
        "source_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["embedded", "git", "path"]
          },
          "uniqueItems": true,
          "minItems": 3
        },
        "verification_postures": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "embedded",
              "pinned_commit",
              "verified_signed_tag",
              "unverified_mutable_ref",
              "unverified_local_source"
            ]
          },
          "uniqueItems": true,
          "minItems": 5
        }
      }
    }
  },
  "$defs": {
    "canonicalizationProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "hash_algorithm"],
      "properties": {
        "profile": {
          "type": "string",
          "const": "runecontext-canonical-json-v1"
        },
        "hash_algorithm": {
          "type": "string",
          "const": "sha256"
        }
      }
    }
  }
}
