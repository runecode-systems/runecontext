{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Context Pack Schema",
  "description": "Deterministic resolved context artifact. Generated, fully closed (no extensions). Schema version 1.",
  "type": "object",
  "required": [
    "schema_version",
    "canonicalization",
    "pack_hash_alg",
    "pack_hash",
    "id",
    "requested_bundle_ids",
    "resolved_from",
    "selected",
    "excluded",
    "generated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version. Unknown versions must fail closed."
    },
    "canonicalization": {
      "type": "string",
      "const": "runecontext-canonical-json-v1",
      "description": "RuneContext canonical JSON profile for context-pack hashing. This alpha.4 profile is a restricted canonical JSON shape for emitted pack values and is intentionally narrower than full RFC 8785 JCS."
    },
    "pack_hash_alg": {
      "type": "string",
      "const": "sha256",
      "description": "Hash algorithm used for `pack_hash`."
    },
    "pack_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Canonical SHA256 hash of the resolved pack after removing the `pack_hash` field, excluding `generated_at`, and applying `runecontext-canonical-json-v1` to the remaining object."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
      "description": "Primary requested context bundle ID for this pack. When multiple top-level bundles are requested, this is the first requested ID."
    },
    "requested_bundle_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
      },
      "minItems": 1,
      "description": "Ordered list of top-level bundle IDs originally requested for this pack before parent linearization."
    },
    "resolved_from": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_mode",
        "source_ref",
        "source_verification",
        "context_bundle_ids"
      ],
      "description": "Metadata about how this pack was resolved.",
      "properties": {
        "source_mode": {
          "type": "string",
          "enum": [
            "embedded",
            "git",
            "path"
          ],
          "description": "How RuneContext was sourced: embedded, git, or path."
        },
        "source_ref": {
          "type": "string",
          "description": "Source reference: branch/tag/commit for git, portable forward-slash relative path for local, 'embedded' for embedded mode."
        },
        "source_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$",
          "description": "Resolved commit SHA (40 hex chars). Required for `git` sources and omitted for source modes that do not resolve a commit."
        },
        "source_verification": {
          "type": "string",
          "enum": [
            "pinned_commit",
            "verified_signed_tag",
            "unverified_mutable_ref",
            "unverified_local_source",
            "embedded"
          ],
          "description": "Verification posture of the source. Determines auditability."
        },
        "verified_signer_identity": {
          "type": "string",
          "description": "Signer identity when `source_verification` is `verified_signed_tag`. Omitted otherwise."
        },
        "verified_signer_fingerprint": {
          "type": "string",
          "description": "Signer fingerprint when `source_verification` is `verified_signed_tag`. Omitted otherwise."
        },
        "context_bundle_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "Ordered list of resolved context bundle IDs (including parents via linearization)."
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "source_verification"
            ],
            "properties": {
              "source_verification": {
                "const": "verified_signed_tag"
              }
            }
          },
          "then": {
            "required": [
              "verified_signer_identity",
              "verified_signer_fingerprint"
            ]
          },
          "else": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "verified_signer_identity"
                  ]
                },
                {
                  "required": [
                    "verified_signer_fingerprint"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "required": [
              "source_mode"
            ],
            "properties": {
              "source_mode": {
                "const": "git"
              }
            }
          },
          "then": {
            "required": [
              "source_commit"
            ],
            "properties": {
              "source_verification": {
                "enum": [
                  "pinned_commit",
                  "verified_signed_tag",
                  "unverified_mutable_ref"
                ]
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "source_mode"
            ],
            "properties": {
              "source_mode": {
                "const": "embedded"
              }
            }
          },
          "then": {
            "properties": {
              "source_verification": {
                "const": "embedded"
              }
            },
            "not": {
              "required": [
                "source_commit"
              ]
            }
          }
        },
        {
          "if": {
            "required": [
              "source_mode"
            ],
            "properties": {
              "source_mode": {
                "const": "path"
              }
            }
          },
          "then": {
            "properties": {
              "source_ref": {
                "allOf": [
                  {
                    "pattern": "^.+$"
                  },
                  {
                    "not": {
                      "pattern": "^[A-Za-z]:"
                    }
                  },
                  {
                    "not": {
                      "pattern": "^/"
                    }
                  },
                  {
                    "not": {
                      "pattern": "^//"
                    }
                  },
                  {
                    "not": {
                      "pattern": "\\\\"
                    }
                  },
                  {
                    "not": {
                      "pattern": "(?:^|/)\\.\\.?($|/)"
                    }
                  }
                ]
              },
              "source_verification": {
                "const": "unverified_local_source"
              }
            },
            "not": {
              "required": [
                "source_commit"
              ]
            }
          }
        }
      ]
    },
    "selected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "standards",
        "specs",
        "decisions"
      ],
      "description": "Selected files by aspect family.",
      "properties": {
        "project": {
          "$ref": "#/$defs/fileInventory"
        },
        "standards": {
          "$ref": "#/$defs/fileInventory"
        },
        "specs": {
          "$ref": "#/$defs/fileInventory"
        },
        "decisions": {
          "$ref": "#/$defs/fileInventory"
        }
      }
    },
    "excluded": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "standards",
        "specs",
        "decisions"
      ],
      "description": "Excluded files by aspect family. All four aspect keys must appear, using empty arrays where nothing was excluded.",
      "properties": {
        "project": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/excludedFile"
          }
        },
        "standards": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/excludedFile"
          }
        },
        "specs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/excludedFile"
          }
        },
        "decisions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/excludedFile"
          }
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Whole-second UTC RFC 3339 timestamp when the pack was generated. Builders must reject sub-second values instead of silently truncating them."
    }
  },
  "$defs": {
    "fileInventory": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256",
          "selected_by"
        ],
        "properties": {
          "path": {
            "type": "string",
            "description": "Relative path to the file within the aspect."
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$",
            "description": "SHA256 hash of the selected file content after UTF-8 text line-ending normalization (CRLF/CR to LF). Non-UTF-8 or binary content is hashed as raw bytes."
          },
          "selected_by": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "bundle",
                "aspect",
                "rule",
                "pattern",
                "kind"
              ],
              "properties": {
                "bundle": {
                  "type": "string",
                  "description": "Bundle ID that selected this file."
                },
                "aspect": {
                  "type": "string",
                  "enum": [
                    "project",
                    "standards",
                    "specs",
                    "decisions"
                  ],
                  "description": "Aspect family."
                },
                "rule": {
                  "type": "string",
                  "enum": [
                    "include",
                    "exclude"
                  ],
                  "description": "Rule type: include or exclude."
                },
                "pattern": {
                  "type": "string",
                  "description": "Normalized bundle rule pattern that matched this file."
                },
                "kind": {
                  "type": "string",
                  "enum": [
                    "exact",
                    "glob"
                  ],
                  "description": "Pattern evaluation kind for the matching rule."
                }
              }
            },
            "description": "Ordered list of rules that selected this file. Last matching rule wins."
          }
        }
      }
    },
    "excludedFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "last_rule"
      ],
      "properties": {
        "path": {
          "type": "string",
          "description": "Relative path to the excluded file within the aspect."
        },
        "last_rule": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "bundle",
            "aspect",
            "rule",
            "pattern",
            "kind"
          ],
          "properties": {
            "bundle": {
              "type": "string",
              "description": "Bundle ID that last matched this file."
            },
            "aspect": {
              "type": "string",
              "enum": [
                "project",
                "standards",
                "specs",
                "decisions"
              ],
              "description": "Aspect family."
            },
            "rule": {
              "type": "string",
              "const": "exclude",
              "description": "Rule type (always exclude for excluded files)."
            },
            "pattern": {
              "type": "string",
              "description": "Normalized bundle rule pattern that last excluded this file."
            },
            "kind": {
              "type": "string",
              "enum": [
                "exact",
                "glob"
              ],
              "description": "Pattern evaluation kind for the excluding rule."
            }
          }
        }
      }
    }
  }
}
